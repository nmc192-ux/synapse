# Restricted design-partner alpha defaults
SYNAPSE_AUTH_REQUIRED=true
SYNAPSE_PLUGIN_EXECUTION_MODE=isolated_hosted
SYNAPSE_HOSTED_PLUGIN_ISOLATION_BACKEND=auto
SYNAPSE_HOSTED_PLUGIN_ALLOW_UNTRUSTED_EXTERNAL=false
SYNAPSE_REDIS_URL=redis://localhost:6379/0
SYNAPSE_REDIS_REQUIRED=true
SYNAPSE_RUNTIME_STATE_FALLBACK_MEMORY=false
SYNAPSE_BROWSER_WORKER_COUNT=1
SYNAPSE_BROWSER_WORKER_HEARTBEAT_INTERVAL_SECONDS=15
SYNAPSE_SCHEDULER_LEASE_TIMEOUT_SECONDS=60
SYNAPSE_SCHEDULER_MAX_ASSIGNMENT_RETRIES=3
SYNAPSE_SCHEDULER_RETRY_BASE_DELAY_SECONDS=1
SYNAPSE_HOSTED_PLUGIN_PARTNER_ALLOWLIST=
SYNAPSE_HOSTED_PLUGIN_NETWORK_ALLOWLIST=
SYNAPSE_HOSTED_PLUGIN_MEMORY_LIMIT_MB=256
SYNAPSE_HOSTED_PLUGIN_CPU_LIMIT_SECONDS=2
SYNAPSE_A2A_SERVICE_AGENT_ALLOWLIST={}

# Alpha launch guidance:
# - keep this file partner-specific, not shared across partners
# - keep domain and plugin allowlists narrow
# - do not enable untrusted external plugins
# - do not use memory fallback in partner-facing environments
